{
  "name": "i18n-timezones",
  "version": "1.1.0",
  "description": "Timezone name translations for 36 locales. Maps friendly and IANA timezone identifiers to localized display names.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./langs/all.json": "./langs/all.json",
    "./langs/*.json": "./langs/*.json",
    "./langs/*": "./langs/*.json"
  },
  "files": [
    "dist",
    "langs"
  ],
  "sideEffects": false,
  "scripts": {
    "generate": "node scripts/yaml-to-json.js",
    "generate:all": "node scripts/generate-all-locales.js",
    "build:data": "npm run generate && npm run generate:all",
    "build": "tsup",
    "test": "vitest run",
    "prepublishOnly": "npm run build:data && npm run build"
  },
  "keywords": [
    "i18n",
    "timezone",
    "timezones",
    "translation",
    "localization",
    "internationalization",
    "l10n",
    "iana",
    "friendly-names"
  ],
  "author": "onomojo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/onomojo/i18n-timezones-js"
  },
  "homepage": "https://github.com/onomojo/i18n-timezones-js",
  "bugs": {
    "url": "https://github.com/onomojo/i18n-timezones-js/issues"
  },
  "engines": {
    "node": ">=14"
  },
  "devDependencies": {
    "i18n-timezones-data": "^1.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
